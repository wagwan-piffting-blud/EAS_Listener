# Web server: bind port for API.
MONITORING_BIND_PORT=8080

# Web server: bind port for dashboard.
WEB_SERVER_PORT=3010

# Web server: bind address (usually should not be modified).
MONITORING_BIND_ADDR=0.0.0.0:${MONITORING_BIND_PORT}

# Timezone for logging and other time-related operations.
TZ=America/Chicago

# TTS engine for CAP alert speech synthesis.
# Supported: "piper" (default, lightweight neural TTS), "espeak-ng", "speechify" (if you specifically want Tom, requires Wine/Speechify and makes the image very large!)
TTS_ENGINE=piper

# TTS model path (Piper only). Defaults to /app/piper/en_US-lessac-medium.onnx in Docker.
# TTS_MODEL=/app/piper/en_US-lessac-medium.onnx
